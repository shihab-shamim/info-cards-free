{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "icb/expandable-animated-card-slider-pro",
  "version": "1.0.0",
  "title": "Expandable Animated Card Slider",
  "category": "info-cards",
  "description": "Expandable Animated Card Slider is a WordPress plugin that allows you to create an expandable animated card slider.",
  "keywords": [
    "slider",
    "card",
    "expandable",
    "animated"
  ],
  "textdomain": "info-cards",
  "attributes": {
    "alignment": {
      "type": "string",
      "default": "center"
    },
    "align": {
      "type": "string",
      "default": "wide"
    },
    "cards": {
      "type": "array",
      "default": [
        {
          "title": "Dota 2",
          "image": "https://www.yudiz.com/codepen/expandable-animated-card-slider/dota-2.jpg",
          "description": "Dota 2 is a multiplayer online battle arena by Valve. The game is a sequel to Defense of the Ancients, which was a community-created mod for Blizzard Entertainment's Warcraft III."
        },
        {
          "title": "The Witcher 3",
          "image": "https://www.yudiz.com/codepen/expandable-animated-card-slider/winter-3.jpg",
          "description": "The Witcher 3: Wild Hunt is an action role-playing game where players control Geralt of Rivia, a monster hunter known as a Witcher, in a sprawling open world."
        },
        {
          "title": "RDR 2",
          "image": "https://www.yudiz.com/codepen/expandable-animated-card-slider/rdr-2.jpg",
          "description": "Red Dead Redemption 2 is an epic tale of life in America's unforgiving heartland, featuring a vast and atmospheric open world and a deep, cinematic story."
        },
        {
          "title": "PUBG Mobile",
          "image": "https://www.yudiz.com/codepen/expandable-animated-card-slider/pubg.jpg",
          "description": "PUBG Mobile is a battle royale shooter where players land on an island and fight to be the last survivor through strategic movement and combat."
        },
        {
          "title": "Fortnite",
          "image": "https://www.yudiz.com/codepen/expandable-animated-card-slider/fortnite.jpg",
          "description": "Fortnite is a battle royale game where 100 players fight to be the last person standing, featuring unique building mechanics and evolving seasonal content."
        },
        {
          "title": "Far Cry 5",
          "image": "https://www.yudiz.com/codepen/expandable-animated-card-slider/far-cry-5.jpg",
          "description": "Far Cry 5 is a 2018 first-person shooter game developed by Ubisoft, set in the fictional Hope County, Montana, featuring a cult-driven narrative."
        }
      ]
    },
    "sliderSettings": {
      "type": "object",
      "default": {
        "autoplayTimeout": 1000,
        "smartSpeed": 800,
        "lazyLoad": true,
        "initialOpenCardNumber": 1,
        "loop": true,
        "nav": false,
        "dots": true,
        "slideIcon": {
          "left": "<svg xmlns='http://www.w3.org/2000/svg' width='24' height='24' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><path d='M15 18l-6-6 6-6'/></svg>",
          "right": "<svg xmlns='http://www.w3.org/2000/svg' width='24' height='24' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><path d='M9 18l6-6-6-6'/></svg>"
        },
        "headingShow": true,
        "descriptionShow": true,
        "titleShow": true,
        "headingText": "Trending Games",
        "mousewheelon": false
      }
    },
    "styles": {
      "type": "object",
      "default": {
        "bg": {},
        "margin": {
          "desktop": {
            "top": "0px",
            "left": "0px",
            "right": "0px",
            "bottom": "0px"
