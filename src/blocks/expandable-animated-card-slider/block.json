            "bottom": "0px"
          },
          "mobile": {
            "top": "0px",
            "left": "0px",
            "right": "0px",
            "bottom": "0px"
          }
        },
        "radius": {
          "top": "0px",
          "left": "0px",
          "right": "0px",
          "bottom": "0px"
        },
        "card": {
          "padding": {
            "top": "0px",
            "left": "24px",
