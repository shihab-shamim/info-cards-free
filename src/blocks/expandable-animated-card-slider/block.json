            }
          },
          "description": {
            "color": "#ffffff",
            "margin": {
              "top": "0px",
              "left": "0px",
              "right": "0px",
              "bottom": "0px"
            },
            "typo": {
              "fontFamily": "",
              "fontCategory": "",
              "fontWeight": "",
              "fontVariant": "",
              "isUploadFont": false,
              "fontSize": {
                "desktop": 16,
                "tablet": 16,
                "mobile": 14
              },
              "fontStyle": "normal",
              "textTransform": "none",
              "textDecoration": "none",
              "lineHeight": "24px",
              "letterSpace": "0px"
            }
          }
        },
        "dots": {
          "active": {
            "color": "#869791"
          },
          "inactive": {
            "color": "#D6D6D6"
          },
          "size": 10,
          "margin": {
            "top": "-20px",
            "left": "0px",
            "right": "0px",
            "bottom": "0px"
          },
          "gap": 0
        },
        "nav": {
          "bg": {
            "type": "solid",
            "color": "rgba(255, 255, 255, 0.8)"
          },
          "color": "#333",
          "size": 40,
          "iconsize": 20,
          "radius": {
            "top": "50px",
            "left": "50px",
            "right": "50px",
            "bottom": "50px"
          }
        }
      }
    }
  },
  "supports": {
    "align": [
      "wide",
      "full"
    ],
    "html": false
  },
  "example": {
    "attributes": {}
  },
  "editorScript": "file:../index.js",
  "editorStyle": "file:../index.css",
  "style": [
    "file:./view.css",
    "owl-carousel",
    "owl-carousel-theme"
  ],
  "render": "file:./render.php",
  "script": [
    "owl-carousel-js",
    "owl-carousel-mousewheel"
  ],
  "viewScript": "file:./view.js"
