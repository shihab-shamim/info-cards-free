            "inactive": {
              "desktop": "300px",
              "tablet": "240px",
              "mobile": "200px"
            }
          },
          "height": {
            "active": {
              "desktop": "400px",
              "tablet": "360px",
              "mobile": "270px"
            },
            "inactive": {
              "desktop": "400px",
              "tablet": "360px",
              "mobile": "270px"
            }
          },
          "imagePosition": "cover",
          "radius": {
            "top": "16px",
            "left": "16px",
            "right": "16px",
            "bottom": "16px"
          },
          "activeShadow": [
            {
              "hOffset": "12px",
              "vOffset": "40px",
              "blur": "40px",
              "spreed": "0px",
              "color": "rgba(0, 0, 0, 0.25)",
              "isInset": false
