          "border": {},
          "padding": {
            "top": "0px",
            "right": "15px",
            "bottom": "10px",
            "left": "15px"
          },
          "image": {
            "height": "300px",
            "objectFit": "cover"
          },
          "title": {
            "color": "#4f585e",
