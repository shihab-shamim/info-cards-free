{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "icb/fold-out-reveal-pro",
  "version": "1.0.0",
  "title": "3D Fold Out Reveal",
  "category": "info-cards",
