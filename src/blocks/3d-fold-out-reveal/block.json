          "btn": {
            "link": "#",
            "text": "Read More"
          }
        }
      ]
    },
    "options": {
      "type": "object",
      "default": {
        "showTitle": true,
        "showSubtitle": true,
        "showDescription": true,
        "showButton": true,
        "showIcons": true,
        "linkOpenInNewTab": true
      }
    },
    "styles": {
      "type": "object",
      "default": {
        "columns": {
          "desktop": 4,
          "tablet": 2,
          "mobile": 1
        },
        "rowGap": 16,
        "columnGap": 16,
        "bg": {},
        "border": {},
        "padding": {
          "desktop": {
            "top": "0px",
            "right": "0px",
